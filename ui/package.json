{
  "name": "excel-importer-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:update": "node -e \"process.platform==='linux'||(console.error('\\n[test:update] Reference screenshots must be generated on Linux (inside the pinned Playwright Docker image). Use npm run test:update:docker.\\n'),process.exit(1))\" && vitest run --update",
    "test:docker": "node scripts/docker-test.mjs test",
    "test:update:docker": "node scripts/docker-test.mjs test:update",
    "test:coverage": "vitest run --coverage --exclude \"**/*.visual.test.tsx\"",
    "test:coverage:full": "vitest run --coverage",
    "test:coverage:docker": "node scripts/docker-test.mjs test:coverage:full",
    "format": "prettier --write \"**/*.{ts,tsx,css,html}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,css,html}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@grigoriev/react-sbb-polarion": "https://github.com/grigoriev/react-sbb-polarion/releases/download/v0.0.2/react-sbb-polarion-0.0.2.tgz",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-istanbul": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "playwright": "^1.61.1",
    "prettier": "3.9.4",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "6.4.3",
    "vitest": "^4.1.10",
    "vitest-browser-react": "^2.2.0"
  },
  "engines": {
    "node": ">=20.9.0",
    "npm": ">=11"
  },
  "packageManager": "npm@11.18.0",
  "allowScripts": {
    "esbuild": true
  }
}
